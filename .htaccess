# ========================================
# OJS 2.4.8.5 Security Configuration
# Complete .htaccess for production security
# ========================================

# Enable URL rewriting
RewriteEngine On

# ========================================
# DEVELOPMENT MODE SETTINGS
# ========================================

# IMPORTANT: Comment out/uncomment sections below based on environment:
# 
# FOR DEVELOPMENT: 
# - Keep development scripts accessible
# - Allow backup directory browsing
# - Less restrictive file access
#
# FOR PRODUCTION:
# - Uncomment all protection rules
# - Block all development scripts
# - Strict file access controls

# Development flag (set to 0 for production)
SetEnv OJS_DEVELOPMENT 1
Options -Indexes
IndexIgnore *

# Disable server signature
ServerSignature Off

# ========================================
# FILE ACCESS PROTECTION
# ========================================

# Block access to sensitive files and directories (allow development scripts)
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|config\.inc\.php|dbscripts|docs|lib|locale|registry|tools|\.git|\.svn|.*\.log|.*\.sql|.*\.bak)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to specific dangerous PHP files (keep development files accessible)
<FilesMatch "^(config\.inc\.php|install\.php|upgrade\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow development/fix scripts (comment out when going to production)
# <FilesMatch "^(fase2.*\.php|emergency.*\.php|.*fix.*\.php|.*test.*\.php|quick.*\.php|deep.*\.php)$">
#     Order Allow,Deny
#     Deny from all
# </FilesMatch>

# Block access to backup directories (but allow access via direct file links if needed)
# <DirectoryMatch "^.*/backup_.*">
#     Order Allow,Deny
#     Deny from all
# </DirectoryMatch>

# Block access to lib directory (except specific allowed files)
<Directory "lib">
    Order Allow,Deny
    Deny from all
</Directory>

# Block access to tools directory
<Directory "tools">
    Order Allow,Deny
    Deny from all
</Directory>

# Block access to docs directory
<Directory "docs">
    Order Allow,Deny
    Deny from all
</Directory>

# Block access to dbscripts directory
<Directory "dbscripts">
    Order Allow,Deny
    Deny from all
</Directory>

# Block access to registry directory
<Directory "registry">
    Order Allow,Deny
    Deny from all
</Directory>

# Block access to locale directory
<Directory "locale">
    Order Allow,Deny
    Deny from all
</Directory>

# Block access to templates directory (except for specific file types)
<Directory "templates">
    <FilesMatch "\.(tpl|css|js|png|jpg|jpeg|gif|ico)$">
        Order Allow,Deny
        Allow from all
    </FilesMatch>
    <FilesMatch "^(?!\.(tpl|css|js|png|jpg|jpeg|gif|ico)$)">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</Directory>

# ========================================
# SECURITY HEADERS
# ========================================

# Prevent clickjacking
<IfModule mod_headers.c>
    Header always append X-Frame-Options SAMEORIGIN
    Header set X-Content-Type-Options nosniff
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
</IfModule>

# ========================================
# HIDE PHP VERSION
# ========================================
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ========================================
# FILE UPLOAD SECURITY
# ========================================

# Block execution of uploaded PHP files
<Directory "files">
    <FilesMatch "\.php$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
    # Allow only safe file types for download
    <FilesMatch "\.(txt|pdf|doc|docx|xls|xlsx|ppt|pptx|png|jpg|jpeg|gif|zip|rar)$">
        Order Allow,Deny
        Allow from all
    </FilesMatch>
</Directory>

# ========================================
# PREVENT ACCESS TO COMMON ATTACK VECTORS
# ========================================

# Block access to common admin/config files
<FilesMatch "^(admin|phpmyadmin|wp-admin|wp-config|configuration|config|settings)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to version control directories
<DirectoryMatch "^.*/(\.git|\.svn|\.hg|\.bzr|CVS)">
    Order Allow,Deny
    Deny from all
</DirectoryMatch>

# Block access to common backup file patterns
<FilesMatch "\.(bak|backup|old|orig|save|swp|tmp)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ========================================
# OJS SPECIFIC PROTECTION
# ========================================

# Protect OJS cache directory
<Directory "cache">
    Order Allow,Deny
    Deny from all
</Directory>

# Protect OJS plugins directory (except public assets)
<Directory "plugins">
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico)$">
        Order Allow,Deny
        Allow from all
    </FilesMatch>
    <FilesMatch "^(?!\.(css|js|png|jpg|jpeg|gif|ico)$)">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</Directory>

# ========================================
# URL REWRITING FOR OJS
# ========================================

# OJS URL rewriting
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [QSA,L]

# ========================================
# PERFORMANCE OPTIMIZATIONS
# ========================================

# Enable compression for text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Set cache headers for static files
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# ========================================
# ERROR PAGES
# ========================================

# Custom error pages (optional)
# ErrorDocument 403 /error/403.html
# ErrorDocument 404 /error/404.html
# ErrorDocument 500 /error/500.html

# ========================================
# IP BLOCKING (uncomment if needed)
# ========================================

# Block specific IPs
# <RequireAll>
#     Require all granted
#     Require not ip 192.168.1.100
#     Require not ip 10.0.0.0/8
# </RequireAll>

# Allow only specific IPs (for admin area)
# <Directory "admin">
#     <RequireAll>
#         Require ip 192.168.1.0/24
#         Require ip YOUR_IP_ADDRESS
#     </RequireAll>
# </Directory>

# ========================================
# MAINTENANCE MODE (uncomment when needed)
# ========================================

# Redirect all requests to maintenance page
# RewriteCond %{REQUEST_URI} !/maintenance.html$
# RewriteCond %{REMOTE_ADDR} !^YOUR_IP_ADDRESS$
# RewriteRule $ /maintenance.html [R=302,L]

# ========================================
# END OF CONFIGURATION
# ========================================